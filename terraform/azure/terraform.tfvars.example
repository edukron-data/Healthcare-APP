resource_group_name = "rg-healthcare-dev"
location = "eastus"
vnet_name = "healthcare-vnet"
vnet_cidr = "10.0.0.0/16"
private_subnet_cidr = "10.0.1.0/24"
public_subnet_cidr = "10.0.2.0/24"
acr_name = "myacr"
acr_sku = "Standard"
keyvault_name = "healthcare-kv"
tenant_id = "<AZURE_TENANT_ID>"
keyvault_secret_name = "db-password"
keyvault_secret_value = "<DB_PASSWORD>"
