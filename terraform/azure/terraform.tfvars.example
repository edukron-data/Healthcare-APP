postgres_admin_user = "dbadmin"
postgres_admin_password = "<DB_PASSWORD>"
postgres_sku = "Standard_B1ms"
postgres_storage_gb = 32
postgres_database_name = "healthcare"
aks_cluster_name = "aks-healthcare-dev"
aks_node_count = 2
aks_node_vm_size = "Standard_B2s"
aks_min_count = 1
aks_max_count = 3
